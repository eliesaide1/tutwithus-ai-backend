# App
APP_NAME=tutwithus-ai-backend
APP_VERSION=0.0.1
ENVIRONMENT=production
DEBUG=false
API_PREFIX=/api/v1
PORT=8001
APEX_CHAT_PORT=8001

# Public URLs
BASE_URL=https://your-app.ondigitalocean.app
BASE_HTTPS_URL=https://your-app.ondigitalocean.app
Apexchat_URL=https://your-app.ondigitalocean.app
APEX_ENGINES_HOST=0.0.0.0
CORS_ORIGINS=https://your-frontend-domain.com

# Security
API_KEY_HEADER=x-api-key
API_KEYS=replace-with-a-long-random-key

# OpenRouter / LLM
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_URL=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=https://your-frontend-domain.com
OPEN_ROUTER_Apexchat_API_KEY=replace-with-openrouter-key
ORCHESTRATOR_MODEL=openai/gpt-4o-mini
GENERAL_TOOL_MODEL=openai/gpt-4o-mini
OPENROUTER_MODEL=openai/gpt-4o-mini
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
LLM_REQUEST_TIMEOUT=60

# MongoDB
MONGODB_URI=mongodb+srv://USER:PASSWORD@HOST/DATABASE?authSource=admin&tls=true
MONGO_DB_NAME=tut-PROD
MONGO_DB_USER=replace-if-used
MONGO_DB_PASSWORD=replace-if-used
MONGO_DB_HOST=replace-if-used
MONGO_DB_PORT=27017
MONGO_ADB_USER=replace-if-used
MONGO_ADB_PASSWORD=replace-if-used
MONGO_DB_DRIVER=mongodb

# Memory
MEMORY_TOOL_MODEL=openai/gpt-4o-mini
MEMORY_EMBEDDING_MODEL=text-embedding-3-small
MEMORY_EMBEDDING_DIMENSIONS=1536
MEMORY_SESSION_INACTIVE_TIMEOUT_MINUTES=30
MEMORY_MAX_FACTS_PER_RETRIEVAL=10
MEMORY_MAX_MESSAGES_PER_RETRIEVAL=20
MEMORY_FACT_CONFIDENCE_THRESHOLD=0.7
MEMORY_SEMANTIC_SIMILARITY_THRESHOLD=0.75

# RAG
RAG_TOOL_MODEL=openai/gpt-4o-mini
RAG_STORAGE_PATH=/app/data/rag
RAG_EMBEDDING_DIM=1536
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=5
RAG_MIN_SCORE=0.2
RAG_MAX_CHUNKS=10

# Tools
WEB_SEARCH_TOOL_MODEL=openai/gpt-4o-mini
WEB_SEARCH_TIMEOUT_SECONDS=20
WEB_SEARCH_RATE_LIMIT_SECONDS=1
NAVIGATION_TOOL_MODEL=openai/gpt-4o-mini
SCREEN_CACHE_TTL_SECONDS=300
DASHBOARD_API_URL=
DASHBOARD_SESSION_TTL_SECONDS=3600
NMS_GENERATE_SQL_URL=
REPORT_GENERATION_TOOL_MODEL=openai/gpt-4o-mini

# Runtime behavior
MAX_RETRIES=3
RETRY_DELAY=1
RETRY_BACKOFF_MULTIPLIER=2
LOG_LEVEL=INFO
LOG_FORMAT=json
MAX_CONVERSATION_HISTORY=20
SESSION_TTL_SECONDS=86400
